# Release configuration for nitpick — filled in once, checked in.
# Nothing here is secret: the signing identity is a certificate *name*, the
# notary profile is a *label* for credentials stored by `notarytool
# store-credentials`, and the EdDSA public key is public by definition.
# The private counterparts live in the login Keychain.
#
# Every value can be overridden from the environment (env wins), so the
# update drill and CI can substitute test values without editing this file.

# The Developer ID Application certificate, as listed by
# `security find-identity -v -p codesigning`.
: "${NITPICK_SIGNING_IDENTITY:=Developer ID Application: Liip AG (QCDJ9EC736)}"

# The keychain profile created by
# `xcrun notarytool store-credentials nitpick-notary --apple-id … --team-id …`.
: "${NITPICK_NOTARY_PROFILE:=nitpick-notary}"

# Where appcast.xml is served from. Stamped into Info.plist as SUFeedURL.
: "${NITPICK_FEED_URL:=https://github.com/Jonathanm10/nitpick/releases/download/updates/appcast.xml}"

# The Sparkle EdDSA public key (`generate_keys -p`). Stamped into Info.plist
# as SUPublicEDKey. The matching private key stays in the Keychain.
: "${NITPICK_ED_PUBLIC_KEY:=tGIibVF+xqt9t/n3cGPHw54iBoJWu6eMfYg7FLukPyQ=}"

# URL prefix under which the release zips are published; generate_appcast
# writes it into each enclosure URL. Usually the directory of the feed URL.
: "${NITPICK_DOWNLOAD_URL_PREFIX:=https://github.com/Jonathanm10/nitpick/releases/download/updates}"
